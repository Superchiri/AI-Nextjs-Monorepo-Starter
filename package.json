{
  "name": "your-repo-name",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@prisma/client": "^7.2.0",
      "better-auth": "^1.4.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @your-repo-name/db db:push",
    "db:studio": "turbo -F @your-repo-name/db db:studio",
    "db:generate": "turbo -F @your-repo-name/db db:generate",
    "db:migrate": "turbo -F @your-repo-name/db db:migrate",
    "db:start": "turbo -F @your-repo-name/db db:start",
    "db:watch": "turbo -F @your-repo-name/db db:watch",
    "db:stop": "turbo -F @your-repo-name/db db:stop",
    "db:down": "turbo -F @your-repo-name/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "prepare": "husky"
  },
  "dependencies": {
    "@your-repo-name/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@your-repo-name/config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "turbo": "^2.6.3",
    "typescript": "catalog:",
    "ultracite": "7.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.10"
}
